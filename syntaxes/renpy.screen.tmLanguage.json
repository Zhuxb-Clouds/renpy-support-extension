    "screen-text": {
      "name": "meta.screen.text.renpy",
      "begin": "(?<=^[ \\t]*)(text)\\b",
      "beginCaptures": {
        "1": {
          "name": "keyword.text.renpy"
        }
      },
      "end": "(?=:)|$",
      "patterns": [
        {
          "include": "source.renpy#strings"
        },
        {
          "match": "(?<=text[ \\t]*)\\b(?:[a-zA-Z_0-9]+)\\b(?=[ \\t]+|$)",
          "name": "entity.name.type.text.renpy"
        },
        {
          "include": "source.renpy#at-statement"
